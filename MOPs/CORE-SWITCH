 CORE-SWITCH
 -----------> CORE-SWITCH 1  <------------------

!discovery + stp + protection
en
conf term
hostname Core-SW1
lldp run
enable password class
line console 0
password cisco
login
line vty 0 4
password cisco
login
exit
service password-encryption
spanning-tree mode rapid-pvst
ip routing

!vlan and intervlan
vlan 10
name Sales
exit
vlan 20 
name IT 
exit
vlan 30
name Admin
exit
vlan 99 
name Management
exit
vlan 90 
name Servers
exit

! SVI for Gateway
interface vlan 10
ip address 10.10.0.1 255.255.255.0
ip helper-address 10.255.255.1
exit
interface vlan 20
ip address 10.20.0.1 255.255.255.0
ip helper-address 10.255.255.1
exit 
interface vlan 30
ip address 10.30.0.1 255.255.255.0
ip helper-address 10.255.255.1
exit
interface vlan 99
ip address 10.99.0.1 255.255.255.0
!ip helper-address 10.255.255.1
exit 
interface vlan 90
ip address 10.90.0.1 255.255.255.0
!ip helper-address 10.255.255.1
exit 


!inter vlan core to dist
interface range f0/1-6
switchport trunk encapsulation dot1q
switchport mode trunk
switchport trunk allowed vlan 10,20,30,90,99
exit

!Load Balancing
spanning-tree vlan 10,30,90 priority 4096
spanning-tree vlan 20,99 priority 8192

! #######
!##Server Port:
interface f0/11
switchport mode access
switchport access vlan 90
exit

interface g0/1
no switchport
ip address 10.255.255.2 255.255.255.252
no shutdown



! ROUTING WITH OSPF
router ospf 1
router-id 2.2.2.2
network 10.255.255.0 0.0.0.3 area 0
network 10.10.0.0 0.0.0.255 area 0
network 10.20.0.0 0.0.0.255 area 0
network 10.30.0.0 0.0.0.255 area 0
network 10.90.0.0 0.0.0.255 area 0
network 10.99.0.0 0.0.0.255 area 0
exit


